---
import "../styles/main.css";

interface Props {
	title?: string;
	breadcrumbs?: string[];
}

const { title, breadcrumbs = [] } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title || "snote"}</title>
	</head>
	<body>
		<div class="container">
			<header class="header">
				<nav class="nav">
					<div class="nav-links">
						<a href="/" class="nav-logo">snote</a>
						<span class="nav-separator">/</span>
						{
							breadcrumbs.map((segment, index) => (
								<>
									<a
										class="nav-item"
										href={`/${breadcrumbs.slice(0, index + 1).join("/")}`}
									>
										{segment.replace(/[_-]+/g, " ")}
									</a>
									{index < breadcrumbs.length - 1 && <span class="nav-separator">/</span>}
								</>
							))
						}
					</div>
				</nav>
			</header>

			<main>
				<article class="markdown">
					<slot />
				</article>
			</main>

			<footer class="footer">
				<p>~</p>
				<p>kesederhanaan adalah kecanggihan tertinggi.</p>
			</footer>
		</div>
	</body>
</html>

<style>
	.container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--space-xl) var(--space-md);
	}

	.header {
		margin-bottom: var(--space-xl);
	}

	.nav {
		font-family: var(--font-mono);
		font-size: 0.9rem;
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
	}

	.nav-logo {
		font-weight: 700;
		color: var(--text-color);
		border: none;
	}

	.nav-item {
		color: var(--text-muted);
		border: none;
		text-transform: lowercase;
	}

	.nav-item:hover {
		color: var(--text-color);
	}

	.nav-separator {
		color: var(--border-color);
	}

	.footer {
		margin-top: var(--space-xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--border-color);
		font-size: 0.85rem;
		color: var(--text-muted);
		text-align: center;
		font-style: italic;
	}

	@media (max-width: 640px) {
		.container {
			padding: var(--space-lg) var(--space-md);
		}
	}
</style>
